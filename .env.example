# ============================================================
# کلاف و کاغذ — متغیرهای محیطی
# یک کپی از این فایل با نام .env بسازید و مقادیر واقعی را پر کنید.
# ============================================================

# === دیتابیس (libSQL / Turso) ===
# برای production روی Vercel: از Turso استفاده کنید (رایگان — turso.tech)
#   1. turso db create kalaf-kaghaz
#   2. turso db tokens create kalaf-kaghaz
#   3. turso db show kalaf-kaghaz --url  →  مقدار URL
# DATABASE_URL=libsql://kalaf-kaghaz-<your-user>.turso.io
# DATABASE_AUTH_TOKEN=<token از مرحله ۲>
#
# برای dev محلی (بدون Turso، فایل لوکال):
DATABASE_URL=file:./db/app.db
DATABASE_AUTH_TOKEN=

# === اطلاعات واریز کارت‌به‌کارت ===
SHOP_BANK_CARD=XXXX-XXXX-XXXX-XXXX
SHOP_BANK_SHABA=IRXX-XXXX-XXXX-XXXX-XXXX-XXXX
SHOP_BANK_OWNER=نام صاحب حساب
SHOP_BANK_NAME=نام بانک

# === راه‌های ارتباطی ===
SHOP_WHATSAPP=98XXXXXXXXXXX
SHOP_TELEGRAM=kolaf_kaghaz
SHOP_INSTAGRAM=kolaf_va_kaghaz
SHOP_PHONE=98XXXXXXXXXXX
SHOP_EMAIL=shop@example.com

# === ارسال ===
SHOP_SHIPPING_COST=65000
SHOP_SHIPPING_METHOD=پست پیشتاز
SHOP_SHIPPING_DAYS=۲ تا ۵ روز کاری
SHOP_FREE_SHIPPING_THRESHOLD=1500000

# === سیاست بازگشت ===
SHOP_RETURN_POLICY=چون محصولات دست‌سازن، تعویض فقط در صورت نقص یا اشتباه در ارسال امکان‌پذیره. لطفاً قبل از سفارش ابعاد و رنگ رو با دقت چک کنید و اگه سوالی دارید از طریق واتساپ بپرسید.

# === پنل مدیریت ===
SHOP_ADMIN_USER=kolaf
SHOP_ADMIN_PASS=kaghaz-1403

# زمان بررسی رسید (ساعت)
SHOP_REVIEW_HOURS=2
